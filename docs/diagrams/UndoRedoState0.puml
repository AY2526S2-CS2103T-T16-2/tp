@startuml UndoRedoState0
!include style.puml
skinparam ClassFontColor #000000
skinparam ClassBorderColor #000000
skinparam ClassBackgroundColor #FFFFAA

title Initial state

package States <<rectangle>> {
    object State1 as "<u>ab0:AddressBook</u>"
    object State2 as "<u>ab1:AddressBook</u>"
    object State3 as "<u>ab2:AddressBook</u>"
}
State1 -[hidden]right-> State2
State2 -[hidden]right-> State3
hide State2
hide State3

object Pointer as "Current State" #FFFFFF
Pointer -up-> State1
@enduml

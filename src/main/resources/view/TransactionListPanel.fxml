<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" spacing="6" styleClass="transaction-list-panel">
  <Label fx:id="title" text="Transactions - Select a person" styleClass="panel-title" />
  <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
    <columns>
      <TableColumn fx:id="indexColumn" text="#" prefWidth="40" />
      <TableColumn fx:id="compoundingColumn" text="Compounding" prefWidth="110" />
      <TableColumn fx:id="directionColumn" text="Direction" prefWidth="90" />
      <TableColumn fx:id="otherPartyColumn" text="Other Party" prefWidth="130" />
      <TableColumn fx:id="amountColumn" text="Amount" prefWidth="90" />
      <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="200" />
      <TableColumn fx:id="statusColumn" text="Status" prefWidth="90" />
      <TableColumn fx:id="dateColumn" text="Date" prefWidth="100" />
    </columns>
  </TableView>
</VBox>
